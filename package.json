  "private": true,
  "packageManager": "pnpm@10.31.0",
  "scripts": {
    "dev:edu-plus": "nx dev edu-plus",
    "dev:edu-core": "nx dev edu-core",
    "dev": "nx run-many -t dev -p edu-plus edu-core --parallel",
