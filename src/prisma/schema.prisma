// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  previewFeatures = ["relationJoins"]
}

datasource db {
  provider = "postgresql"
}

enum FeatureType {
  ROUTE
  COMPONENT
  API
}

enum HttpMethod {
  GET
  POST
  PUT
  DELETE
  PATCH
  OPTIONS
  HEAD
}

//////////////////////////////////////////////////
// ORGANIZATION (Tenant)
//////////////////////////////////////////////////

model Organization {
  id          Int      @id @default(autoincrement())
  name        String
  slug        String   @unique
  metaDataRef String?

  memberships OrganizationMembership[]
  policies    Policy[]
  userTypes   UserType[]
  collections FeatureCollection[]
}

//////////////////////////////////////////////////
// GLOBAL USER (Identity)
//////////////////////////////////////////////////

model User {
  id                     Int      @id @default(autoincrement())
  userId                 String   @unique
  email                  String   @unique
  passwordHash           String
  systemToken            String?
  incorrectLoginAttempts Int
  maxLoginAttempts       Int
  currentActiveLogins    Json?
  maxActiveLogins        Int
  metaDataRef            String?

  @@index([userId, email])
  memberships OrganizationMembership[]
}

//////////////////////////////////////////////////
// ORGANIZATION MEMBERSHIP (User ↔ Org)
//////////////////////////////////////////////////

model OrganizationMembership {
  id             Int @id @default(autoincrement())
  organizationId Int
  userId         Int
  userTypeId     Int
  statusId       Int
  metaDataRef    String?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userType     UserType     @relation(fields: [userTypeId], references: [id], onDelete: Cascade)
  status       UserStatus   @relation(fields: [statusId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
}

//////////////////////////////////////////////////
// GLOBAL PLATFORM FEATURES
//////////////////////////////////////////////////

model ModuleFeature {
  id            Int      @id @default(autoincrement())
  permissionKey String   @unique
  type          FeatureType
  method        HttpMethod?
  metaDataRef   String?

  featureLists  CollectionFeatureMap[]
}

//////////////////////////////////////////////////
// ORG-SCOPED POLICY
//////////////////////////////////////////////////

model Policy {
  id             Int      @id @default(autoincrement())
  organizationId Int
  policyName     String
  description    String?   @db.VarChar(5000)
  metaDataRef    String?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  featureLists FeatureCollection[]
  userTypes    UserType[]

  @@index([organizationId])
  @@index([organizationId, policyName])
}

//////////////////////////////////////////////////
// ORG-SCOPED FEATURE COLLECTION
//////////////////////////////////////////////////

model FeatureCollection {
  id             Int      @id @default(autoincrement())
  organizationId Int
  name           String
  description    String?  @db.VarChar(5000)
  policyId       Int
  metaDataRef    String?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  policy       Policy       @relation(fields: [policyId], references: [id], onDelete: Cascade)

  features    CollectionFeatureMap[]

  @@unique([organizationId, name])
  @@index([organizationId, policyId])
}

//////////////////////////////////////////////////
// COLLECTION ↔ FEATURE MAP (GLOBAL FEATURES)
//////////////////////////////////////////////////

model CollectionFeatureMap {
  id              Int @id @default(autoincrement())
  collectionId    Int
  moduleFeatureId Int

  featureCollection FeatureCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  moduleFeature     ModuleFeature     @relation(fields: [moduleFeatureId], references: [id], onDelete: Cascade)

  @@unique([collectionId, moduleFeatureId])
}

//////////////////////////////////////////////////
// ORG-SCOPED ROLE
//////////////////////////////////////////////////

model UserType {
  id             Int      @id @default(autoincrement())
  organizationId Int
  userType       String
  userPolicyId   Int
  metaDataRef    String?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  policy       Policy       @relation(fields: [userPolicyId], references: [id], onDelete: Cascade)

  memberships OrganizationMembership[]

  @@unique([organizationId, userType])
  @@index([organizationId])
}

//////////////////////////////////////////////////
// GLOBAL USER STATUS
//////////////////////////////////////////////////

model UserStatus {
  id          Int      @id @default(autoincrement())
  status      String   @unique
  metaDataRef String?

  memberships OrganizationMembership[]
}

model dbMetaData {
  id    Int     @id @default(autoincrement())
  dirty Boolean @default(false)
}