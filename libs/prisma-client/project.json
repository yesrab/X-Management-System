{
  "name": "prisma-client",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/prisma-client/src",
  "projectType": "library",
  "targets": {
    "generate": {
      "command": "prisma generate",
      "options": { "cwd": "{workspaceRoot}" },
      "cache": true,
      "inputs": [
        "{workspaceRoot}/libs/prisma-client/prisma/schema.prisma",
        "{workspaceRoot}/prisma.config.ts"
      ],
      "outputs": ["{workspaceRoot}/libs/prisma-client/src/generated"]
    },
    "migrate-deploy": {
      "command": "prisma migrate deploy",
      "options": { "cwd": "{workspaceRoot}" }
    },
    "migrate-dev": {
      "command": "prisma migrate dev",
      "options": { "cwd": "{workspaceRoot}" }
    },
    "seed": {
      "command": "prisma db seed",
      "options": { "cwd": "{workspaceRoot}" }
    }
  }
}
